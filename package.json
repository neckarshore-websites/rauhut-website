{
  "name": "rauhut-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --grep-invert @external",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:quick": "node scripts/lighthouse.mjs --quick",
    "lighthouse:desktop": "node scripts/lighthouse.mjs --quick --profile=desktop",
    "lighthouse:mobile": "node scripts/lighthouse.mjs --quick --profile=mobile-4g",
    "lighthouse:5g": "node scripts/lighthouse.mjs --quick --profile=mobile-5g",
    "test:lighthouse:unit": "node --test scripts/lighthouse-profiles.test.mjs",
    "test:unit": "node --test src/app/actions/inquiry.test.ts scripts/lighthouse-url.test.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "next": "16.2.6",
    "nodemailer": "9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lighthouse": "13.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
